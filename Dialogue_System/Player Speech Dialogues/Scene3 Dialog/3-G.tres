[sub_resource type="Resource" id="Resource_gkgaa"]
script = ExtResource("1_gkgaa")
name = "Salaryman"
text = "I... I WANT TO DO ART AS MY JOB! I WANT TO PURSUE MY DREAMS!"
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

[sub_resource type="Resource" id="Resource_edjtt"]
script = ExtResource("1_gkgaa")
name = "Salaryman"
text = "I NEVER WANTED TO BE A CORPORATE SLAVE!"
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

[sub_resource type="Resource" id="Resource_imuqt"]
script = ExtResource("1_gkgaa")
name = "Salaryman"
text = "I'm sorry... to my wife, and my daughter, if I couldn't muster up the courage to quit my job."
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

[sub_resource type="Resource" id="Resource_dsou0"]
script = ExtResource("1_gkgaa")
name = "Salaryman"
text = "But I'm gonna be fine. I know I will be."
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

[sub_resource type="Resource" id="Resource_gv41m"]
script = ExtResource("1_gkgaa")
name = "Salaryman"
text = "Thank you, Japanese stranger."
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

