[ext_resource type="Script" uid="uid://bw6pub8fdcttc" path="res://Dialogue_System/pair.gd" id="1_ace7r"]
[ext_resource type="Script" uid="uid://b3mnv4pljudrt" path="res://Dialogue_System/dialogue.gd" id="2_hgn8d"]

[sub_resource type="Resource" id="Resource_ddaed"]
script = ExtResource("1_ace7r")
name = "Salary Man"
text = "\"The hero slays the dragon but it's big claws left his chest with a wide gash.\""
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

[sub_resource type="Resource" id="Resource_i7mnb"]
script = ExtResource("1_ace7r")
name = "Salary Man"
text = "\"His party returned without him, but they all lived happily ever after.\""
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

[sub_resource type="Resource" id="Resource_cj8ir"]
script = ExtResource("1_ace7r")
name = "Little Girl"
text = "\"Why did he die, he promised his family that he'd come back, didn't he?"
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

[sub_resource type="Resource" id="Resource_igsp5"]
script = ExtResource("1_ace7r")
name = "Salary Man"
text = "\"He did, but he couldn't keep it. So his family did not live happily.\""
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

[sub_resource type="Resource" id="Resource_qkbyf"]
script = ExtResource("1_ace7r")
name = "Little Girl"
text = "\"But you are here dad, so I am happy.\""
metadata/_custom_type_script = "uid://bw6pub8fdcttc"

